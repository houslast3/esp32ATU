  "sensors": [
    {
      "id": "bme280",
      "name": "BME280",
      "manufacturer": "Bosch",
      "type": "I2C",
      "description": "Temperatura, Umidade, Pressao barometrica",
      "addresses": ["0x76", "0x77"],
      "protocol": {"bus": "I2C", "speed_hz": 100000, "reg_width": 8},
      "vars": [
        {"name": "bme280_temp", "unit": "°C", "decimals": 2, "formula": "((raw >> 16) & 0xFF) | ((raw >> 8) & 0xFF00) | (raw & 0xFF0000)"},
        {"name": "bme280_hum", "unit": "%", "decimals": 2, "formula": "raw & 0xFFFF"},
        {"name": "bme280_press", "unit": "hPa", "decimals": 2, "formula": "(raw >> 8) & 0xFFFFFF"}
      ],
      "test_code_url": "https://raw.githubusercontent.com/houslast3/esp32-sensors/main/code/bme280.c"
    },
